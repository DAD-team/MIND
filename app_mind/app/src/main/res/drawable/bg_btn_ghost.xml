<?xml version="1.0" encoding="utf-8"?>
<!-- Nút ghost: cùng pill shape với bg_btn_primary, nền trắng solid +
     viền teal — rõ ràng nhưng vẫn subordinate so với nút primary filled. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#405CABB5">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="28dp" />
            <stroke android:width="2dp" android:color="@color/accent_teal" />
        </shape>
    </item>
</ripple>
