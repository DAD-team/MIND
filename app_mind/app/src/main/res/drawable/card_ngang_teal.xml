<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer -->
    <item
        android:bottom="0dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#185CABB5" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Card body -->
    <item
        android:bottom="2dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#FAF8F0" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1.5dp"
                android:color="@color/accent_teal" />
        </shape>
    </item>
</layer-list>
