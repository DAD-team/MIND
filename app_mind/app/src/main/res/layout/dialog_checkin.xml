<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_overlay"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="28dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito"
        android:text="@string/checkin_title"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/nunito"
        android:text="@string/checkin_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <!-- Row 1: Vui vẻ, Buồn, Căng thẳng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Vui vẻ -->
        <LinearLayout
            android:id="@+id/moodHappy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_mood_circle"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginHorizontal="4dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_mood_happy" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/nunito"
                android:text="@string/checkin_mood_happy"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Buồn -->
        <LinearLayout
            android:id="@+id/moodSad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_mood_circle"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginHorizontal="4dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_mood_sad" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/nunito"
                android:text="@string/checkin_mood_sad"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Căng thẳng -->
        <LinearLayout
            android:id="@+id/moodStressed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_mood_circle"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginHorizontal="4dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_mood_stressed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/nunito"
                android:text="@string/checkin_mood_stressed"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2: Hào hứng, Bình thường, Mệt mỏi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Hào hứng -->
        <LinearLayout
            android:id="@+id/moodExcited"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_mood_circle"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginHorizontal="4dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_mood_excited" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/nunito"
                android:text="@string/checkin_mood_excited"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Bình thường -->
        <LinearLayout
            android:id="@+id/moodNeutral"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_mood_circle"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginHorizontal="4dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_mood_neutral" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/nunito"
                android:text="@string/checkin_mood_neutral"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Mệt mỏi -->
        <LinearLayout
            android:id="@+id/moodTired"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_mood_circle"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginHorizontal="4dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_mood_tired" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/nunito"
                android:text="@string/checkin_mood_tired"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Video option (only visible when consent >= 2) -->
    <TextView
        android:id="@+id/btnCheckinVideo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/nunito"
        android:text="@string/checkin_video_btn"
        android:textColor="@color/accent_teal"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Confirm button -->
    <TextView
        android:id="@+id/btnCheckinConfirm"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_btn_primary"
        android:fontFamily="@font/nunito"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:text="@string/checkin_btn_confirm"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
