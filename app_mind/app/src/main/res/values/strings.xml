    <!-- PHQ-9 (Đánh giá sâu) -->
    <string name="phq9_title">Đánh giá chi tiết</string>
    <string name="phq9_intro">Để hiểu rõ hơn, mình muốn hỏi thêm vài câu nữa — chỉ khoảng 2 phút.</string>
    <string name="phq9_q3">Khó ngủ, ngủ không sâu, hoặc ngủ quá nhiều</string>
    <string name="phq9_q4">Cảm thấy mệt mỏi hoặc ít năng lượng</string>
    <string name="phq9_q5">Ăn không ngon hoặc ăn quá nhiều</string>
    <string name="phq9_q6">Cảm thấy tồi tệ về bản thân — hoặc rằng mình là người thất bại</string>
    <string name="phq9_q7">Khó tập trung vào việc, như đọc sách hoặc xem điện thoại</string>
    <string name="phq9_q8">Nói hoặc cử động chậm hơn bình thường; hoặc ngược lại — bồn chồn, bất an</string>
    <string name="phq9_q9">Nghĩ rằng mình sẽ tốt hơn nếu chết đi, hoặc nghĩ đến việc tự làm hại bản thân</string>
    <string name="phq9_q10">Nếu bạn gặp bất kỳ vấn đề nào ở trên, chúng làm khó khăn cho việc học tập, làm việc, hoặc hòa hợp với mọi người ở mức nào?</string>
    <string name="phq9_q10_opt_0">Không khó khăn</string>
